# FindOpenCL.cmake — Android NDK override
#
# Placed in android/app/src/main/cpp/ and prepended to CMAKE_MODULE_PATH so that
# CMake finds THIS file before its built-in FindOpenCL.cmake when any subdirectory
# (including llama.cpp/ggml/src/ggml-opencl/) calls find_package(OpenCL [REQUIRED]).
#
# Why a custom finder?
#   The NDK sysroot does not ship libOpenCL.so — it is a vendor library present
#   only on the device (/vendor/lib64/libOpenCL.so on Mali devices like the M31).
#   CMake's built-in FindOpenCL.cmake calls find_library(OpenCL_LIBRARY OpenCL)
#   which searches the NDK sysroot and fails with OpenCL_FOUND=FALSE, aborting the
#   build even though the library WILL be present on the device.
#
# This file satisfies find_package(OpenCL REQUIRED) for Android by:
#   1. Using the Khronos OpenCL headers vendored at
#      android/app/src/main/cpp/opencl-headers/  (downloaded from KhronosGroup/OpenCL-Headers)
#   2. Creating an INTERFACE target OpenCL::OpenCL that points to a link-time stub
#      libOpenCL.so that exports all standard OpenCL API symbols as empty stubs.
#      The stub is excluded from the APK — the real Mali vendor libOpenCL.so is
#      used at runtime.
#
# On non-Android hosts the standard CMake FindOpenCL.cmake is used as normal.

if(ANDROID)
    # ── Headers ────────────────────────────────────────────────────────────────
    get_filename_component(_OCL_SELF_DIR "${CMAKE_CURRENT_LIST_FILE}" DIRECTORY)
    set(_OCL_INCLUDE_DIR "${_OCL_SELF_DIR}/opencl-headers")

    if(NOT EXISTS "${_OCL_INCLUDE_DIR}/CL/cl.h")
        message(FATAL_ERROR
            "OpenCL headers not found at ${_OCL_INCLUDE_DIR}/CL/cl.h\n"
            "Run from android/app/src/main/cpp/:\n"
            "  git clone --depth 1 https://github.com/KhronosGroup/OpenCL-Headers opencl-headers\n"
            "Then rebuild.")
    endif()

    # ── Link-time stub libOpenCL.so ─────────────────────────────────────────────
    # The NDK sysroot does NOT ship libOpenCL.so — it is a vendor library present
    # only on the device (/vendor/lib64/libOpenCL.so on Mali devices like the M31).
    # lld with --no-undefined (set by the NDK toolchain for all shared libraries)
    # requires every symbol referenced by libggml-opencl.so to be resolvable at
    # link time, either from another .so or from this stub.
    #
    # The stub must export ALL OpenCL C API symbols that ggml-opencl.cpp references.
    # A one-function stub is not sufficient — the linker will emit "undefined symbol"
    # errors for each cl* function the code calls.
    #
    # The stub is compiled as a shared library named libOpenCL.so using the same NDK
    # cross-toolchain, satisfying lld at build time. It is then EXCLUDED from the APK
    # (see packagingOptions in build.gradle) so that at runtime the device's real
    # Mali vendor libOpenCL.so is used instead.
    if(NOT TARGET OpenCLStub)
        set(_OCL_STUB_SRC "${CMAKE_BINARY_DIR}/opencl_stub.c")
        file(WRITE "${_OCL_STUB_SRC}"
"/* OpenCL link-time stub for Android NDK builds.\n"
" * Provides empty implementations of all standard OpenCL C API functions.\n"
" * This library is excluded from the APK; the Mali vendor libOpenCL.so is\n"
" * loaded at runtime instead.\n"
" *\n"
" * Every cl* symbol that ggml-opencl.cpp references must appear here so that\n"
" * lld (--no-undefined) is satisfied at link time.\n"
" */\n"
"#define CL_TARGET_OPENCL_VERSION 300\n"
"#include <CL/cl.h>\n"
"\n"
"/* ---- Platform ---------------------------------------------------------- */\n"
"CL_API_ENTRY cl_int CL_API_CALL\n"
"clGetPlatformIDs(cl_uint n, cl_platform_id* p, cl_uint* np)\n"
"{ (void)n; (void)p; (void)np; return CL_SUCCESS; }\n"
"\n"
"CL_API_ENTRY cl_int CL_API_CALL\n"
"clGetPlatformInfo(cl_platform_id p, cl_platform_info i, size_t s, void* v, size_t* sr)\n"
"{ (void)p;(void)i;(void)s;(void)v;(void)sr; return CL_SUCCESS; }\n"
"\n"
"CL_API_ENTRY void* CL_API_CALL\n"
"clGetExtensionFunctionAddressForPlatform(cl_platform_id p, const char* n)\n"
"{ (void)p;(void)n; return (void*)0; }\n"
"\n"
