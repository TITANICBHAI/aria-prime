"clCreateSubDevices(cl_device_id d, const cl_device_partition_property* p, cl_uint n, cl_device_id* od, cl_uint* nd)\n"
"{ (void)d;(void)p;(void)n;(void)od;(void)nd; return CL_SUCCESS; }\n"
