modules = ["java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE='feat(orch): real RegistryStageExecutor + ComponentInterface adapters, end the noop era. EngineComponents.kt wraps LlamaEngine/VisionEngine/AgentLoop/PolicyNetwork as ComponentInterface; CentralOrchestrator.registerInstance() + RegistryStageExecutor dispatches stages to live adapters; AgentForegroundService heartbeat loop + bus->orchestration error bridge so agent failures actually fire the LLM diagnostic path.' bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
