modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(ci): bump pinned llama.cpp tag from b6000 to b8935. The previous b6000 NDK build progressed through CMake configure (CPU, Vulkan, OpenCL all OK) and into the actual compile step, but llama_jni.cpp uses several APIs that did not exist yet at b6000: llama_context_params.flash_attn_type, LLAMA_FLASH_ATTN_TYPE_AUTO/DISABLED, llama_set_adapters_lora, mtmd_context_params.flash_attn_type/warmup, llama_opt_params.optimizer_type, GGML_OPT_OPTIMIZER_TYPE_ADAMW. Verified against tag b8935 raw headers (include/llama.h, ggml/include/ggml-opt.h) that all symbols are present. b8500 also works; chose b8935 (latest stable) to track upstream bugfixes.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
