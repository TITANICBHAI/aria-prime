modules = ["java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(link): rename common -> llama-common in target_link_libraries(llama-jni). The b8935 common/CMakeLists.txt renamed the target from 'common' to 'llama-common' (and split out 'llama-common-base'); the old name causes ld.lld error: unable to find library -lcommon. Vulkan + SPIRV staging worked perfectly: ggml-vulkan.cpp compiled cleanly, only the final libllama-jni.so link step failed.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
