modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(ci): vendor llama.cpp @ b4870 in build-android.yml. Root cause of CMake failure 'add_subdirectory given source .../cpp/llama.cpp which is not an existing directory': .gitmodules is empty in the repo, so 'submodules: recursive' in the checkout step is a no-op. Added a new step 'Vendor llama.cpp @ b4870' that shallow-clones the pinned release tag (matches docs/07_BUILD_AND_INSTALL.md) into android/app/src/main/cpp/llama.cpp before any Gradle/CMake task, and asserts both CMakeLists.txt and tools/mtmd/ exist. The .git directory is removed post-clone so the .cxx cache key (hashes cpp/**) stays stable.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
