modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"port: orchestration layer (14 files, ~1965 LOC) from AII donor to Kotlin under core/orchestration/ — closes AGENT_INSTRUCTIONS gap #3. CentralOrchestrator is now a plain coroutine class (no Service); ProblemSolvingBroker takes a pluggable ProblemSolver (Groq dependency dropped); OrchestrationScheduler stage execution is pluggable (FeedbackSystem/ErrorResolutionWorkflow deps dropped); CircuitBreaker package typo fixed. Updated DONOR_INVENTORY, ARCHITECTURE, AGENT_INSTRUCTIONS, replit.md.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
