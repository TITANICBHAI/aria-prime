modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(orchestration): add explicit ': Unit' return type to 4 single-expression suspend functions wrapping stateMutex.withLock { ... } in CentralOrchestrator.{initialize,stop} and OrchestrationScheduler.{start,stop}. Without it, Kotlin inferred the return type as Int because the last lambda expression was Log.i(...) — Android's android.util.Log methods return Int (bytes written). The bare 'return' statements inside then failed compileDebugKotlin with: 'Return type mismatch: expected kotlin.Int, actual kotlin.Unit'. Fixes 4 errors at CentralOrchestrator.kt:73,123 and OrchestrationScheduler.kt:61,78.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
