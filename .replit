modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(vulkan): install spirv-headers apt package and stage /usr/include/spirv into build-local include dir for NDK cross-compile. The b8935 ggml-vulkan.cpp:28 includes 'spirv/unified1/spirv.hpp' (KhronosGroup/SPIRV-Headers C++ enum wrappers), which apt's spirv-headers ships at /usr/include/spirv/. NDK clang's --sysroot points at the Android NDK sysroot and ignores /usr/include, so installing the package is necessary but not sufficient — we also stage the headers under CMAKE_BINARY_DIR/spirv_include and add it via include_directories(BEFORE ...) (plain -I, not -isystem) so user-include search order beats the sysroot. Mirrors the existing vulkan.hpp staging pattern. Without this Vulkan backend cannot compile (CPU + OpenCL still would).\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
