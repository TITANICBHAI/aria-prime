modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE='feat(ui): Round 4 — surface orchestration subsystem + fix dead UI. New DiagnosticsScreen shows ComponentRegistry + HealthMonitor (per-component status, errors, restarts, circuit-breaker, heartbeat), recent orchestration.* bus events (last 50, color-coded), last LLM problem-solver resolution, and a real floating-chat overlay toggle. AgentViewModel adds OrchestrationStatusUi/EventUi/ComponentUi data classes, _orchestrationStatus + _orchestrationEvents StateFlows, refreshOrchestrationStatus() polling, public toggleFloatingChat()/startFloatingChat()/stopFloatingChat(), and an _overlayPermissionRequestFlow that ARIAComposeApp routes to ACTION_MANAGE_OVERLAY_PERMISSION (mirrors screen-capture launcher). FloatingChatService gains a static isRunning flag flipped in onCreate/onStartCommand/onDestroy. Bus collector funnels every orchestration.* event into the ring buffer via handleOrchestrationEvent. SettingsScreen gets a Diagnostics nav card; the Model Catalog card lost its dead empty-onClick clickable modifier (now purely informational). Audit summary: 3 real findings — orchestration zero UI surface, floating chat unreachable without agent run, dead Settings button — all fixed.' bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
