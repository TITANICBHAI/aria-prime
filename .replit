modules = ["java-graalvm22.3", "python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push to GitHub"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 server/serve.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Push to GitHub"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "COMMIT_MESSAGE=\"fix(cmake): set LLAMA_CURL OFF in android/app/src/main/cpp/CMakeLists.txt. llama.cpp's common/CMakeLists.txt line 85 aborts the configure step with 'Could NOT find CURL' when LLAMA_CURL is on (default), because the NDK toolchain has no libcurl. We do not need HTTP model fetching on Android (models are sideloaded), so this option is purely vestigial here. Configure step previously got past CMake error CXX1429 caused by missing tools/mtmd; this is the next blocker. CPU/Vulkan/OpenCL backends already configured cleanly per CI log lines 581-647.\" bash scripts/push.sh"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["python3", "server/serve.py"]
